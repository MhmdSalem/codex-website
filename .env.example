# ── Public site config ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://codex-tech.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@codex-tech.com
NEXT_PUBLIC_CONTACT_PHONE=+201000000000
NEXT_PUBLIC_WHATSAPP_NUMBER=201000000000

# ── Database (MongoDB) ───────────────────────────────────────────────────
# For a local install:        mongodb://127.0.0.1:27017
# For MongoDB Atlas, paste your full SRV connection string.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=codex_website

# ── Auth ─────────────────────────────────────────────────────────────────
# A long random string. Generate one with:  openssl rand -base64 48
AUTH_SECRET=replace-me-with-a-long-random-string-min-32-chars

# ── Initial seeded admin (used only by `npm run seed`) ───────────────────
SEED_ADMIN_EMAIL=admin@codex.local
SEED_ADMIN_PASSWORD=Codex@1234
SEED_ADMIN_NAME=Codex Admin
