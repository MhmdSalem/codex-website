* text=auto eol=lf

# Shell scripts must always have LF line endings (they run on Linux servers)
*.sh        text eol=lf
*.bash      text eol=lf
deploy/*    text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.avif      binary
*.ico       binary
*.svg       text
*.mp4       binary
*.webm      binary
*.woff      binary
*.woff2     binary
